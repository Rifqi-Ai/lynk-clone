APP_NAME="Linka"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=linka
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_STORE=redis
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

MAIL_MAILER=log
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="hello@linka.dev"
# MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ─── Payment Gateway (Duitku) ───
# Dev mode: set DUITKU_PRODUCTION=false (mock payment)
# Prod mode: get real keys from https://duitku.com
DUITKU_PRODUCTION=false
DUITKU_API_KEY=your_duitku_api_key_here
DUITKU_MERCHANT_CODE=your_merchant_code_here
DUITKU_DEFAULT_METHOD=VC

# ─── Google OAuth (optional) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback

# ─── WhatsApp Notifications (optional) ───
# Providers: log (dev), wablas, fonnte
# Dev: leave WHATSAPP_PRODUCTION=false → messages logged to laravel.log
# Prod: sign up at https://wablas.com or https://fonnte.com
WHATSAPP_PROVIDER=log
WHATSAPP_API_KEY=
WHATSAPP_SENDER=
WHATSAPP_PRODUCTION=false
